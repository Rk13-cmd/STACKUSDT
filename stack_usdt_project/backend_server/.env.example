# STACK USDT Backend Environment Variables
# Copia este archivo a .env y completa los valores

# Server
PORT=3001

# Supabase
SUPABASE_URL=https://hpfuoqejinckybhsqkub.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# NOWPayments
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret

# URLs
BACKEND_URL=https://stackusdt.onrender.com
FRONTEND_URL=https://stackusdt.onrender.com

# Security (optional)
# Comma-separated IPs allowed to access admin panel
# ADMIN_IP_WHITELIST=192.168.1.1,10.0.0.1
# Set to empty to disable IP whitelist (all IPs allowed)
ADMIN_IP_WHITELIST=

# Disable admin audit logging (for dev)
NO_ADMIN_AUDIT=
